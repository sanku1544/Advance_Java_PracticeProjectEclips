package com.tka.feb18;

import java.util.List;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

@Repository
public class StaffDao {
	
	@Autowired
	SessionFactory sf;
	
	public Staff getStaff(int id) {
		Session ssn = sf.openSession();
		return ssn.get(Staff.class, id);
		
	}

	public String addStaff(Staff s) {
		Session ssn = sf.openSession();
		ssn.save(s);
		ssn.beginTransaction().commit();
		return s.getName()+"  "+"staff inserted sucess--";
	}

	public String updateStaff(Staff s) {
		Session ssn = sf.openSession();
		ssn.update(s);
		ssn.beginTransaction().commit();
		return s.getName()+"  "+"staff update sucess--";
	}

	public String deleteStaff(int id) {
		String show=null;
		Session ssn = sf.openSession();
		Staff st = ssn.get(Staff.class, id);
		if(st!=null) {
		ssn.delete(st);
		ssn.beginTransaction().commit();
		show="Delete successfully.....";
		}else {
			show="user not found...";
		}
		return show;
		
	}

	public List<Staff> getAllStaff() {
		Session ssn = sf.openSession();
		List list = ssn.createQuery("From Staff").list();
		return list;
	}

	
	
	
}
