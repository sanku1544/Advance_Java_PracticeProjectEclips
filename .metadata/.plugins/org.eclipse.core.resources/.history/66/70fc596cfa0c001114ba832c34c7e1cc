package com.tka.feb18;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

@Service
public class StaffService {
		
	@Autowired
	StaffDao sd;
	

	public Staff getStaff(int id) {
		return sd.getStaff(id);
		
	}

	public String addStaff(Staff s) {
		return sd.addStaff(s);
		
	}

	public String updateStaff(Staff s) {
		return sd.updateStaff(s);
	}

	public String deleteStaff(int id) {
		return sd.deleteStaff(id);		
	}

	public List<Staff> getAllStaff() {
		return sd.getAllStaff();
	}

	public List<Staff> getBySalary(int sal) {
		return sd.getBySalary(sal);
	}

	public List<Staff> getListBaseOnExp(int start, int end) {
		return sd.getListBaseOnExp(start,end);
	}

	public List<Staff> getHighSalaryStaff() {
		return sd.getHighSalaryStaff();
	}

	public String getStaffMinExp() {
		return sd.getStaffMinExp();
	}

	public List<Staff> getByProfile(String profile) {
		return sd.getByProfile(profile);
	}

	public List<Staff> getByNotProfile(String profile) {
		return sd.getByNotProfile(profile);
	}

	
	
	
}
