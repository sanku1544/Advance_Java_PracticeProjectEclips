package com.tka.Test;

import java.util.List;

import com.tka.entity.Customer;
import com.tka.entity.Product;
import com.tka.service.Order;

public class zomatoMenu {

	public static void main(String[] args) {
		int totalBill=0;
		Customer c1= new Customer(1,"Sanket",4516532215454L);
		Order r1= new Order();
		List<Product> orderItems = r1.orderItems();
		for(Product p:orderItems) {
			totalBill+=p.getPrice();
		}
		System.out.println("Customer name:- "+c1.getName());
		System.out.println("Customer mob:- "+c1.getMob());
		System.out.println("List of products:- ");
		for(Product p:orderItems) {
			System.out.println(p.getName()+" "+p.getPrice());
		}
		System.out.println("totalBill is:- "+totalBill);

	}

}
