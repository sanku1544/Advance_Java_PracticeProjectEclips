package com.tka.feb18;

import java.util.ArrayList;
import java.util.List;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

@Repository
public class StaffDao {
	
	@Autowired
	SessionFactory sf;
	
	public Staff getStaff(int id) {
		Session ssn = sf.openSession();
		return ssn.get(Staff.class, id);
		
	}

	public String addStaff(Staff s) {
		Session ssn = sf.openSession();
		ssn.save(s);
		ssn.beginTransaction().commit();
		return s.getName()+"  "+"staff inserted sucess--";
	}

	public String updateStaff(Staff s) {
		Session ssn = sf.openSession();
		ssn.update(s);
		ssn.beginTransaction().commit();
		return s.getName()+"  "+"staff update sucess--";
	}

	public String deleteStaff(int id) {
		String show=null;
		Session ssn = sf.openSession();
		Staff st = ssn.get(Staff.class, id);
		if(st!=null) {
		ssn.delete(st);
		ssn.beginTransaction().commit();
		show="Delete successfully.....";
		}else {
			show="user not found...";
		}
		return show;
		
	}

	public List<Staff> getAllStaff() {
		Session ssn = sf.openSession();
		List<Staff> list = ssn.createQuery("From Staff").list();
		return list;
	}

	public List<Staff> getBySalary(int sal) {
		Session ssn = sf.openSession();
		List<Staff> list = ssn.createQuery("From Staff").list();
		List<Staff> stList=new ArrayList<>();
		for(Staff s:list) {
			if(s.getSalary()>sal) {
				stList.add(s);
			}
		}
		return stList;
	}

	public List<Staff> getListBaseOnExp(int start, int end) {
		Session ssn = sf.openSession();
		List<Staff> list = ssn.createQuery("From Staff").list();
		List<Staff> stList=new ArrayList<>();
		for(Staff s:list) {
			if(s.getExperience()>start && s.getExperience()<end) {
				stList.add(s);
			}
		}
		return stList;
	}

	public List<Staff> getHighSalaryStaff() {
		Session ssn = sf.openSession();
		int max=0;
		List<Staff> list = ssn.createQuery("From Staff").list();
		for(Staff s:list) {
			if(max<s.getSalary()) {
				max=s.getSalary();
			}
		}
		
		List<Staff> stList=new ArrayList<>();
		for(Staff s:list) {
			if(s.getSalary()==max) {
				stList.add(s);
			}
		}
		return stList;
	}

	public String getStaffMinExp() {
		Session ssn = sf.openSession();
		int min=Integer.MAX_VALUE;
		String name=null;
		List<Staff> list = ssn.createQuery("From Staff").list();
		for(Staff s:list) {
			if(min>s.getExperience()) {
				min=s.getExperience();
				name=s.getName();
			}
		}
		
		return name;
	}

	
	
	
}
