package com.tka.feb17;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

@Repository
public class DaoStudent {

	@Autowired
	SessionFactory sf;
	
	public Student getStudetnByid(int id) {
		Session ss = sf.openSession();
		return ss.get(Student.class, id);
	}
	
	public void addStudent(Student s) {
		Session ss = sf.openSession();
		ss.save(s);
		ss.beginTransaction().commit();
		System.err.println("Insert into db..........");
	
		
	}
	public void updateStudent(Student s) {
		Session ss = sf.openSession();
		ss.update(s);
		ss.beginTransaction().commit();
		System.err.println("update into db..........");		
	}

	public void deleteStudent(int id) {
		Session ss = sf.openSession();
		Student stud = ss.get(Student.class, id);
		if(stud!=null) {
			ss.delete(stud);
			ss.beginTransaction().commit();
			System.err.println("delete into db..........");
		}else {
			System.out.println("Record was not found");
		}
		
	}
	

}
