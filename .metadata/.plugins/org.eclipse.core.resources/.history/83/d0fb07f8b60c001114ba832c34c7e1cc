package com.tka.feb17;

import java.util.ArrayList;
import java.util.List;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RestController;

import jakarta.websocket.server.PathParam;

@RestController
public class StudentController {
		
	List<Student> slist=new ArrayList<>();
	@GetMapping("/")
	String Student() {
		return "Welcome";
	}
	
	@GetMapping("/student")
	List<Student> getStudent(){
		slist.add(new Student(2,"Nikam",25));
		slist.add(new Student(3,"Jagdish",21));
		slist.add(new Student(4,"Akash",23));
		return slist;
	}
	
	@PutMapping("/login")
	void putFromBrowser(@PathParam("uaername") String use,@PathParam("password") String pass) {
		System.out.println(use);
		System.out.println(pass);
	}
	
	@PutMapping("/stud")
	public String addStudent(@RequestBody Student  s) {
		slist.add(s);
		return "Data added";
	}
	
	@PutMapping("/{id}")
	public String updateStudent(@PathVariable int id,@RequestBody Student s1) {
		for(Student s:slist) {
			if(s.getId()==id) {
				s.setName(s1.getName());
				s.setAge(s1.getAge());
				return "Student upadated";
			}
		}
		return "Student not found";
	}
	
	@GetMapping("/getAll")
	List<Student> getAllStudents() {
		List<Student> ss=new ArrayList<>();
		for(Student s:slist) {
			ss.add(s);
		}
		return ss;
	}
	
	
	

}
