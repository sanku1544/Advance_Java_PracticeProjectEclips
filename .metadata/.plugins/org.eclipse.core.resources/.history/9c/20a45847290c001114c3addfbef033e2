		slist.add(new Student(4,"Akash",23));
		return slist;
	}
	
	@PutMapping("/login")
	void putFromBrowser(@PathParam("") String use,@PathParam("") String pass) {
		System.out.println(use);
		System.out.println(pass);
	}
	
	@PutMapping("/stud")
	public String addStudent(@RequestBody Student  s) {
		slist.add(s);
		return "Data added";
	}
	
	@PutMapping("/stud/update")
	void updateStudent(@RequestBody Student  s) {
		s.setId(0)
	}
	
	
	

}
