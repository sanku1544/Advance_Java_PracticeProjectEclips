package com.tka.UserAuthentication;

import java.util.ArrayList;
import java.util.List;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

@Repository
public class UserDao {
	
	@Autowired
	SessionFactory sf;

	public String registerUser(User user) {
		Session ss = sf.openSession();
		ss.save(user);
		ss.beginTransaction().commit();
		return "User Register Successfully";
	}

	public String loginUser(String email, String password) {
		Session ss = sf.openSession();
		String res="";
		List<User> list = ss.createQuery("from User").list();
		for(User u:list) {
			if(u.getEmail().equals(email)) {
				if(u.getPassword().equals(password)) {
					res="User loging succesfully";
				}else {
					res="Password is wrong";
				}
			}else {
				res="Check your email";
			}
		}
		return res;
	}

	

	public String findByEmailAndPassword(String email, String password) {

	    Session ss = sf.openSession();

	    User user = (User) ss.createQuery(
	            "from User where email = :email and password = :password")
	            .setParameter("email", email)
	            .setParameter("password", password)
	            .uniqueResult();

	    if (user == null) {
	        return "Invalid email or password!";
	    }

	    return "Login successful! Here is user profile:\n" + user.toString();
	}

}
