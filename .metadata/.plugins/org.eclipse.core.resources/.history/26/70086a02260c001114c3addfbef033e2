package com.tka.feb17;

import java.util.ArrayList;
import java.util.List;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RestController;

import jakarta.websocket.server.PathParam;

@RestController
public class StudentController {
		
	@GetMapping("/")
	Student getStud(Student stu) {
		return stu;
	}
	
	@GetMapping("/student")
	Student getStudent(){
		Student s1= new Student();
		s1.setId(1);
		s1.setName("Sanket");
		s1.setAge(22);
		return s1;
	}
	
//	localhost:8080/login?username=admin&passwors=admin@123
	@PutMapping("/login")
	void putFromBrowser(@PathParam("") String use,@PathParam("") String pass) {
		System.out.println(use);
		System.out.println(pass);
	}
	
	@PutMapping("/stud")
	void putStudent(@PathParam("") int id,@PathParam("") String name,@PathParam("") int age) {
		List<Student> s1=new ArrayList<>();
		s1.add(new Student(id,name,age));
		s1.forEach(System.out::println);

	}
	

}
